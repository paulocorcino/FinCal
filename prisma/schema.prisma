generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String      @id @default(cuid())
  name          String?
  email         String      @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  alertaProximosDias Int    @default(7)
  accounts      Account[]
  sessions      Session[]
  categorias    Categoria[]
  contas        Conta[]
  lancamentos   Lancamento[]
}

model Conta {
  id           String   @id @default(cuid())
  userId       String
  nome         String
  papel        String
  saldoInicial Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lancamentos Lancamento[]

  @@index([userId])
}

model Categoria {
  id        String   @id @default(cuid())
  userId    String
  nome      String
  tipo      String
  cor       String?
  icone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lancamentos Lancamento[]

  @@unique([userId, nome, tipo])
}

model Lancamento {
  id              String   @id @default(cuid())
  userId          String
  contaId         String
  categoriaId     String
  tipo            String
  valor           Int
  data            String
  status          String
  recorrenciaId   String?
  transferenciaId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  conta     Conta      @relation(fields: [contaId], references: [id], onDelete: Restrict)
  categoria Categoria  @relation(fields: [categoriaId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([userId, data])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}
